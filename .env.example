# Required on Vercel if you want explicit region pinning.
# Keep send + receive on the same queue region.
WEBHOOK_CATCHER_QUEUE_REGION=iad1

# Optional: local/dev token override for Vercel Queue API auth.
# On Vercel, OIDC auth is used automatically.
# WEBHOOK_CATCHER_QUEUE_TOKEN=

# Optional capture + token settings.
WEBHOOK_CATCHER_EVENT_RETENTION_SECONDS=86400
WEBHOOK_CATCHER_MAX_CAPTURE_BYTES=65536
